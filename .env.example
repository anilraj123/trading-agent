# Alpaca Trading API (https://alpaca.markets)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://api.alpaca.markets

# LLM Configuration (Anthropic Claude)
LLM_PROVIDER=anthropic
LLM_API_KEY=your_anthropic_api_key_here
LLM_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Risk Management Parameters
RISK_MAX_POSITION_PCT=0.10
RISK_DAILY_LOSS_LIMIT=-5.00
RISK_STOP_LOSS_PCT=-0.03
RISK_MAX_TRADES_PER_DAY=10
RISK_MAX_HOLDING_DAYS=3

# Trading Parameters
BLACKLIST=MSFT
TIMEZONE=US/Pacific
TRADING_INTERVAL_MINUTES=15
WATCHLIST=AAPL,MSFT,TSLA,SPY,QQQ
SIMULATED_ACCOUNT_SIZE=200

# Technical Analysis Thresholds
TA_RSI_OVERSOLD=35
TA_RSI_OVERBOUGHT=65
TA_RSI_WEIGHT=1.0
TA_MACD_WEIGHT=1.0
TA_BB_WEIGHT=1.0
TA_BB_LOWER_THRESHOLD=0.10
TA_BB_UPPER_THRESHOLD=0.90
TA_TREND_WEIGHT=1.0
TA_MOM_WEIGHT=1.0
TA_MOM_THRESHOLD=2.0
TA_VOL_THRESHOLD=1.2
TA_VOL_BOOST=1.2
TA_MIN_BUY_SCORE=0.65
TA_MIN_SELL_SCORE=0.6
TA_STOP_LOSS_PCT=-0.03

# Notifications (ntfy.sh - free, no API key needed)
# 1. Install ntfy app on your phone: https://ntfy.sh
# 2. Pick a unique topic name (e.g., trading-anil-2026)
# 3. Subscribe to that topic in the app
# 4. Set the topic name below
NOTIFY_PROVIDER=ntfy
NOTIFY_NTFY_TOPIC=your_unique_topic_name_here
