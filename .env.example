ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

LLM_PROVIDER=openrouter
LLM_API_KEY=your_openrouter_key_here
LLM_MODEL=anthropic/claude-3.5-haiku

RISK_MAX_POSITION_PCT=0.10
RISK_DAILY_LOSS_LIMIT=-5.00
RISK_STOP_LOSS_PCT=-0.03
RISK_MAX_TRADES_PER_DAY=5

TRADING_INTERVAL_MINUTES=15
WATCHLIST=AAPL,MSFT,TSLA,SPY,QQQ
SIMULATED_ACCOUNT_SIZE=200

# Notifications (WhatsApp via CallMeBot - Free)
# Step 1: Save +34 644 55 06 54 as a contact on your phone
# Step 2: Send this message on WhatsApp: "I allow callmebot to send me messages"
# Step 3: You'll receive an API key back
# Step 4: Add the API key and your phone number below
NOTIFY_PROVIDER=whatsapp
NOTIFY_WHATSAPP_API_KEY=your_api_key_here
NOTIFY_WHATSAPP_PHONE=your_phone_number_with_country_code

# Alternative: ntfy.sh (free push notifications, no setup)
# NOTIFY_PROVIDER=ntfy
# NOTIFY_NTFY_TOPIC=trading-agent-2026
